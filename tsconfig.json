{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "drizzle.config.ts"],
  "exclude": ["dist", "node_modules", "legacy"]
}
