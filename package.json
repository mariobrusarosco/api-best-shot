{
  "name": "football-platform-api",
  "version": "1.0.2",
  "private": true,
  "description": "Football Platform API",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "tsx watch src/apps/api/server.ts",
    "build": "tsc",
    "start": "node dist/src/apps/api/server.js",
    "typecheck": "tsc --noEmit",
    "cf:deploy": "wrangler deploy",
    "cf:containers": "wrangler containers list",
    "cf:images": "wrangler containers images list",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check --dialect=postgresql --out=./drizzle",
    "db:studio": "drizzle-kit studio",
    "db:seed:almanac": "tsx scripts/seed-almanac.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:psql": "docker compose exec postgres psql -U postgres -d football_platform"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "playwright": "^1.61.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/containers": "^0.3.7",
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.109.0"
  }
}
