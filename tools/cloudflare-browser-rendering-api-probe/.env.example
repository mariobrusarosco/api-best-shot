CLOUDFLARE_ACCOUNT_ID=replace-with-your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-browser-rendering-edit-token

SOFASCORE_JSON_URL=https://www.sofascore.com/api/v1/unique-tournament/17/season/76986/standings/total

# Keep this at 11000 on Workers Free. Cloudflare Quick Actions Free allows 1 request every 10 seconds.
ATTEMPTS=1
WAIT_MS=11000

GOTO_WAIT_UNTIL=domcontentloaded
GOTO_TIMEOUT_MS=30000

USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
