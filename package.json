{
  "name": "football-platform-api",
  "version": "1.0.1",
  "private": true,
  "description": "Football Platform API",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/apps/api/index.ts",
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/src/apps/api/index.js",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:psql": "docker compose exec postgres psql -U postgres -d football_platform"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "postgres": "^3.4.5",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
